# AgentSOC POC environment.
# Copy to .env only when you intentionally want local overrides.

# Required only for real OpenAI NCE calls in small runs/tests.
OPENAI_API_KEY=

# Default OpenAI model for the NCE layer.
AGENTSOC_LLM_MODEL=gpt-5.4-nano

# auto: use OpenAI when OPENAI_API_KEY exists for small runs, otherwise mock.
# mock: always use deterministic local hypotheses.
# openai: require OPENAI_API_KEY and fail if missing.
AGENTSOC_LLM_MODE=auto

# Hard budget for real OpenAI calls in one run.
AGENTSOC_MAX_LLM_CALLS=30

# Keep false. Stress/benchmark paths are mock-only by default.
AGENTSOC_ALLOW_STRESS_LLM=false

# Default artifact root relative to AGENT-SOC.
AGENTSOC_ARTIFACTS_DIR=output
